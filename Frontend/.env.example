# Rice Leaf Disease Detection - Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Backend Server Configuration
# Point this to your ML model backend server that processes rice leaf images
# The backend should accept POST requests at: {BACKEND_URL}/api/detect
# Format: http://localhost:5000 or https://your-backend-server.com
BACKEND_URL=http://127.0.0.1:8000


# Note: The frontend will use this URL to send images for disease detection
# Your backend's /api/detect endpoint should:
# 1. Accept multipart/form-data with 'image' field
# 2. Process the image with your ML model
# 3. Return JSON response:
#    {
#      "disease": "Bacterial Leaf Blight",
#      "confidence": 0.95
#    }
